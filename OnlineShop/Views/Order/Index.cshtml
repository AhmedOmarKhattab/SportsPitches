@model IEnumerable<Order>
@{
    ViewData["Title"] = "الطلبات";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

}

<h1>الطلبات</h1>

<table class="mt-3 table table-striped table-hover">
    <thead>
        <tr>
            <th>رقم الطلب</th>
            <th>اسم العميل</th>
            <th>البريد الإلكتروني</th>
            <th>رقم الهاتف</th>
            <th>العنوان</th>
            <th>تاريخ الطلب</th>
            <th>الحالة</th>
            <th> حالة الطلب</th>

        </tr>
    </thead>
    <tbody>
        @if (Model.Any())
        {
            foreach (var o in Model)
            {
                <tr>
                    <td>@o.OrderNo</td>
                    <td>@o.Name</td>
                    <td>@o.Email</td>
                    <td>@o.PhoneNo</td>
                    <td>@o.Address</td>
                    <td>@o.OrderDate</td>
                    <td>@o.Status</td>
                    <td>
                        <a asp-action="ChangeStauts" asp-controller="Order"
                           class="btn btn-success btn-sm me-1"
                           asp-route-id="@o.Id"
                           asp-route-status="true">
                            <i class="fas fa-check"></i> قبول
                        </a>
                        <a asp-action="ChangeStauts" asp-controller="Order"
                           class="btn btn-danger btn-sm"
                           asp-route-id="@o.Id"
                           asp-route-status="false">
                            <i class="fas fa-times"></i> رفض
                        </a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>