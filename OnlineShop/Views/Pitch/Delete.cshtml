@model Pitch
@{
    ViewData["Title"] = "حذف المنتج";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

}

<style>
    body {
        direction: rtl;
        text-align: right;
    }

    .card {
        border-radius: 15px;
    }

    label {
        font-weight: bold;
    }

    .form-control {
        border-radius: 10px;
    }

    .img-box img {
        border-radius: 10px;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }

    .warning-box {
        background: #fff3cd;
        padding: 15px;
        border-radius: 10px;
        color: #856404;
        font-weight: bold;
        text-align: center;
    }
</style>

<br />

<h2 class="text-danger mb-4">حذف المنتج</h2>

<form asp-controller="Product" asp-action="Delete" method="post">
    <div class="card p-4 shadow-sm">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="row">

            <!-- البيانات -->
            <div class="col-md-8">

                <input type="hidden" asp-for="Id" />

                <div class="row mb-3">
                    <div class="col-4"><label>اسم المنتج</label></div>
                    <div class="col-8">
                        <input asp-for="Name" readonly class="form-control" />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-4"><label>السعر</label></div>
                    <div class="col-8">
                        <input asp-for="Price" readonly class="form-control" />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-4"><label>العنوان</label></div>
                    <div class="col-8">
                        <input asp-for="Address" readonly class="form-control" />
                    </div>
                </div>

                
                <div class="row mb-3">
                    <div class="col-4"><label>نوع المنتج</label></div>
                    <div class="col-8">
                        <input value="@Model.PitchType?.Name" readonly class="form-control" />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-4"><label>التصنيف</label></div>
                    <div class="col-8">
                        <input value="@Model.SpecialTag?.Name" readonly class="form-control" />
                    </div>
                </div>

                <!-- ✅ Product Brand -->
                
                <div class="row mb-3">
                    <div class="col-4"><label>متوفر</label></div>
                    <div class="col-8">
                        <input asp-for="IsAvailable" disabled type="checkbox" />
                    </div>
                </div>

                <!-- تحذير -->
                <div class="warning-box mt-4">
                    هل أنت متأكد أنك تريد حذف هذا المنتج؟
                </div>

                <!-- أزرار -->
                <div class="mt-4">
                    <input type="submit" asp-route-id="@Model.Id" class="btn btn-danger" value="حذف" />
                    <a asp-action="Index" class="btn btn-outline-success">العودة للقائمة</a>
                </div>

            </div>

            <!-- الصورة -->
            <div class="col-md-4 text-center img-box">
                <img src="~/files/images/@(Model.Image ?? "noimage.png")" width="220" class="img-thumbnail" />
                <p class="text-muted mt-2">صورة المنتج</p>
            </div>

        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}