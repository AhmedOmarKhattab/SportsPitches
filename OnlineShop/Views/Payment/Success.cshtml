@* @model FiveStadium.Models.Order
@{
    ViewData["Title"] = "Payment Success";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body text-center">
            <h1 class="text-success display-4"><i class="bi bi-check-circle-fill"></i> Payment Successful!</h1>
            <p class="lead">Thank you for your order, <strong>@Model.Name</strong>!</p>
            <hr />
            <h4 class="mb-3">Order Details</h4>
            <ul class="list-group text-start">
                <li class="list-group-item"><strong>Order No:</strong> @Model.OrderNo</li>
                <li class="list-group-item"><strong>Email:</strong> @Model.Email</li>
                <li class="list-group-item"><strong>Phone:</strong> @Model.PhoneNo</li>
                <li class="list-group-item"><strong>Address:</strong> @Model.Address</li>
                <li class="list-group-item"><strong>Order Date:</strong> @Model.OrderDate.ToString("f")</li>
                <li class="list-group-item"><strong>Status:</strong> @Model.Status</li>
            </ul>

            <h5 class="mt-4">Items Ordered</h5>
            <table class="table table-bordered table-striped mt-2">
                <thead class="table-light">
                    <tr>
                        <th>Product</th>
                        <th>Quantity</th>
                        <th>Price</th>
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.ProductName</td>
                            <td>@item.Quantity</td>
                            <td>@item.Price.ToString("C")</td>
                            <td>@(item.Price * item.Quantity).ToString("C")</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3" class="text-end fw-bold">Grand Total:</td>
                        <td class="fw-bold">
                            @Model.Items.Sum(i => i.Price * i.Quantity).ToString("C")
                        </td>
                    </tr>
                </tfoot>
            </table>

            <a href="/" class="btn btn-primary mt-3"><i class="bi bi-house-door-fill"></i> Return to Home</a>
        </div>
    </div>
</div>
 *@