@model LoginModel
@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}
<h2 class="auth-form-title">مرحباً بعودتك 👋</h2>
<p class="auth-form-sub">سجّل دخولك للوصول إلى حسابك ومتابعة طلباتك</p>
<form asp-action="Login">
    <div asp-validation-summary="All" class="auth-validation" style="display:none"
         id="valSummary"></div>
    <div class="auth-field">
        <label asp-for="UserName">اسم المستخدم / البريد الإلكتروني</label>
        <div class="auth-field-wrap">
            <input asp-for="UserName"
                   class="auth-input"
                   placeholder="example@email.com"
                   autocomplete="username" />
            <i class="bi bi-person-fill auth-field-icon"></i>
        </div>
        <span asp-validation-for="UserName" class="auth-error"></span>
    </div>
    <div class="auth-field">
        <label asp-for="Password">كلمة المرور</label>
        <div class="auth-field-wrap">
            <input asp-for="Password"
                   class="auth-input"
                   placeholder="••••••••"
                   type="password"
                   id="passwordInput"
                   autocomplete="current-password" />
            <i class="bi bi-lock-fill auth-field-icon" id="toggleIcon"
               style="cursor:pointer;pointer-events:all"
               onclick="togglePass()"></i>
        </div>
        <span asp-validation-for="Password" class="auth-error"></span>
    </div>
    <div class="auth-remember">
        <input asp-for="RememberMe" type="checkbox" id="rememberMe" />
        <label for="rememberMe">تذكّرني في هذا الجهاز</label>
    </div>
    <button type="submit" class="auth-submit">
        <i class="bi bi-box-arrow-in-right"></i>
        تسجيل الدخول
    </button>
    <div class="auth-link-row">
        ليس لديك حساب؟ <a asp-action="Register">إنشاء حساب جديد</a>
    </div>
</form>
<script>
    function togglePass() {
        var inp = document.getElementById('passwordInput');
        var ico = document.getElementById('toggleIcon');
        if (inp.type === 'password') {
            inp.type = 'text';
            ico.className = 'bi bi-eye-slash-fill auth-field-icon';
        } else {
            inp.type = 'password';
            ico.className = 'bi bi-lock-fill auth-field-icon';
        }
    }
    var vs = document.getElementById('valSummary');
    if (vs && vs.querySelector('li')) vs.style.display = 'block';
</script>
@section ValidationSection {
    <partial name="_ValidationScriptsPartial" />
}
