@model RegisterModel
@{
    ViewData["Title"] = "إنشاء حساب";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}
<style>
    .auth-agree {
        display: flex;
        align-items: flex-start;
        gap: 0.55rem;
        margin-bottom: 1.5rem;
        font-size: 0.82rem;
        color: var(--muted);
        line-height: 1.5;
        flex-wrap: wrap;
    }

        .auth-agree input[type="checkbox"] {
            width: 16px;
            height: 16px;
            accent-color: var(--primary);
            cursor: pointer;
            margin-top: 2px;
            flex-shrink: 0;
        }

    .agree-link {
        color: var(--primary);
        font-weight: 700;
        text-decoration: none;
    }

        .agree-link:hover {
            text-decoration: underline;
        }

    .pass-strength-bar {
        height: 4px;
        background: var(--border);
        border-radius: 4px;
        margin-top: 0.5rem;
        overflow: hidden;
        display: none;
    }

    .strength-fill {
        height: 100%;
        width: 0%;
        border-radius: 4px;
        transition: width 0.3s ease, background 0.3s ease;
    }

    .strength-label {
        font-size: 0.72rem;
        font-weight: 700;
        margin-top: 0.3rem;
        display: block;
    }
</style>

<h2 class="auth-form-title">إنشاء حساب جديد ✨</h2>
<p class="auth-form-sub">انضم إلينا اليوم واستمتع بأفضل تجربة تسوق</p>

<form asp-action="Register">

    <div asp-validation-summary="All" class="auth-validation" id="valSummary" style="display:none"></div>

    <div class="auth-field">
        <label asp-for="Email">البريد الإلكتروني</label>
        <div class="auth-field-wrap">
            <input asp-for="Email"
                   class="auth-input"
                   placeholder="example@email.com"
                   autocomplete="email" />
            <i class="bi bi-envelope-fill auth-field-icon"></i>
        </div>
        <span asp-validation-for="Email" class="auth-error"></span>
    </div>

    <div class="auth-field">
        <label asp-for="Password">كلمة المرور</label>
        <div class="auth-field-wrap">
            <input asp-for="Password"
                   class="auth-input"
                   placeholder="••••••••"
                   type="password"
                   id="passInput"
                   autocomplete="new-password" />
            <i class="bi bi-lock-fill auth-field-icon" id="passIcon"
               style="cursor:pointer;pointer-events:all"
               onclick="toggleField('passInput','passIcon')"></i>
        </div>
        <span asp-validation-for="Password" class="auth-error"></span>
        <div class="pass-strength-bar" id="strengthBar">
            <div class="strength-fill" id="strengthFill"></div>
        </div>
        <span class="strength-label" id="strengthLabel"></span>
    </div>

    <div class="auth-field">
        <label asp-for="ConfirmPassword">تأكيد كلمة المرور</label>
        <div class="auth-field-wrap">
            <input asp-for="ConfirmPassword"
                   class="auth-input"
                   placeholder="••••••••"
                   type="password"
                   id="confirmInput"
                   autocomplete="new-password" />
            <i class="bi bi-lock-fill auth-field-icon" id="confirmIcon"
               style="cursor:pointer;pointer-events:all"
               onclick="toggleField('confirmInput','confirmIcon')"></i>
        </div>
        <span asp-validation-for="ConfirmPassword" class="auth-error"></span>
    </div>

    <div class="auth-agree">
        <input asp-for="IsAgree" type="checkbox" id="agreeCheck" />
        <label for="agreeCheck">
            أوافق على <a href="#" class="agree-link">شروط الخدمة</a>
            و<a href="#" class="agree-link">سياسة الخصوصية</a>
        </label>
        <span asp-validation-for="IsAgree" class="auth-error" style="display:block;margin-top:.3rem"></span>
    </div>

    <button type="submit" class="auth-submit">
        <i class="bi bi-person-plus-fill"></i>
        إنشاء الحساب
    </button>

    <div class="auth-link-row">
        لديك حساب بالفعل؟ <a asp-action="Login">تسجيل الدخول</a>
    </div>

</form>

<script>
    function toggleField(inputId, iconId) {
        var inp = document.getElementById(inputId);
        var ico = document.getElementById(iconId);
        if (inp.type === 'password') {
            inp.type = 'text';
            ico.className = 'bi bi-eye-slash-fill auth-field-icon';
        } else {
            inp.type = 'password';
            ico.className = 'bi bi-lock-fill auth-field-icon';
        }
        ico.style.cursor = 'pointer';
        ico.style.pointerEvents = 'all';
    }

    document.getElementById('passInput').addEventListener('input', function () {
        var val = this.value;
        var bar = document.getElementById('strengthBar');
        var fill = document.getElementById('strengthFill');
        var label = document.getElementById('strengthLabel');

        if (!val) { bar.style.display = 'none'; label.textContent = ''; return; }
        bar.style.display = 'block';

        var score = 0;
        if (val.length >= 8) score++;
        if (/[A-Z]/.test(val)) score++;
        if (/[0-9]/.test(val)) score++;
        if (/[^A-Za-z0-9]/.test(val)) score++;

        var configs = [
            { pct: '25%',  color: '#ef4444', text: 'ضعيفة جداً',  textColor: '#ef4444' },
            { pct: '50%',  color: '#f59e0b', text: 'مقبولة',       textColor: '#f59e0b' },
            { pct: '75%',  color: '#3b82f6', text: 'جيدة',         textColor: '#3b82f6' },
            { pct: '100%', color: '#10b981', text: 'قوية جداً ✓',  textColor: '#10b981' },
        ];
        var c = configs[score - 1] || configs[0];
        fill.style.width = c.pct;
        fill.style.background = c.color;
        label.textContent = 'قوة كلمة المرور: ' + c.text;
        label.style.color = c.textColor;
    });

    var vs = document.getElementById('valSummary');
    if (vs && vs.querySelector('li')) vs.style.display = 'block';
</script>

@section ValidationSection {
    <partial name="_ValidationScriptsPartial" />
}
