    <script>
        /* ── Navbar scroll effect ── */
        const navbar = document.getElementById('mainNavbar');
        window.addEventListener('scroll', () => {
            navbar.classList.toggle('scrolled', window.scrollY > 20);
        }, { passive: true });

        /* ── Mobile toggle ── */
        const mobileToggle = document.getElementById('mobileToggle');
        const navPanel     = document.getElementById('navPanel');
        const toggleIcon   = document.getElementById('toggleIcon');

        mobileToggle.addEventListener('click', () => {
            const isOpen = navPanel.classList.toggle('open');
            toggleIcon.className = isOpen ? 'bi bi-x-lg' : 'bi bi-list';
            document.body.style.overflow = isOpen ? 'hidden' : '';
        });

        /* ── Dropdown toggle ── */
        function toggleDrop(trigger) {
            // trigger can be the button or the .nav-drop element itself
            const drop = trigger.classList.contains('nav-drop')
                ? trigger
                : trigger.closest('.nav-drop');
            if (!drop) return;

            const isOpen = drop.classList.contains('open');
            // close all
            document.querySelectorAll('.nav-drop.open').forEach(d => d.classList.remove('open'));
            // open this one if it was closed
            if (!isOpen) drop.classList.add('open');
        }

        /* ── Close dropdowns on outside click ── */
        document.addEventListener('click', (e) => {
            if (!e.target.closest('.nav-drop') && !e.target.closest('.nav-user-btn')) {
                document.querySelectorAll('.nav-drop.open').forEach(d => d.classList.remove('open'));
            }
        });

        /* ── Active link highlight ── */
        const currentPath = window.location.pathname;
        document.querySelectorAll('.navbar__links a').forEach(link => {
            if (link.getAttribute('href') === currentPath) link.classList.add('active');
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
