</style>

<script>
    /* Grid / List view toggle */
    function setView(mode) {
        const grid = document.getElementById('productsGrid');
        const gBtn = document.getElementById('gridViewBtn');
        const lBtn = document.getElementById('listViewBtn');
        if (mode === 'list') {
            grid.classList.add('list-view');
            lBtn.classList.add('sp-view-btn--active');
            gBtn.classList.remove('sp-view-btn--active');
        } else {
            grid.classList.remove('list-view');
            gBtn.classList.add('sp-view-btn--active');
            lBtn.classList.remove('sp-view-btn--active');
        }
    }

    /* Mobile filter toggle */
    function toggleMobileFilters() {
        const body  = document.getElementById('sidebarBody');
        const arrow = document.getElementById('filterArrow');
        const isOpen = body.classList.toggle('open');
        arrow.classList.toggle('open', isOpen);
    }
</script>
