<!-- ═══════════════════ STYLES ═══════════════════ -->
<style>
    @@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&family=Rajdhani:wght@500;600;700&display=swap');

    :root {
        --st-green: #00C853;
        --st-green-d: #00952e;
        --st-gold: #FFD740;
        --st-gold-d: #c9a800;
        --st-blue: #1E88E5;
        --st-red: #FF3D57;
        --st-dark: #0a0e1a;
        --st-dark2: #111827;
        --st-card: #161d30;
        --st-muted: #8892b0;
        --st-bg: #f0f4f8;
        --bounce: cubic-bezier(.34,1.56,.64,1);
    }

    *, *::before, *::after {
        box-sizing: border-box;
    }

    body {
        font-family: 'Tajawal', sans-serif;
        background: var(--st-bg);
        color: #1a1f36;
        direction: rtl;
        overflow-x: hidden;
    }

    .wu-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }

    /* ══ HERO ══ */
    .wu-hero {
        min-height: 88vh;
        background: linear-gradient(150deg, #060c18 0%, #0d1a30 45%, #041008 100%);
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 6rem 2rem 4rem;
    }

    .wh-grid-lines {
        position: absolute;
        inset: 0;
        display: flex;
        pointer-events: none;
    }

        .wh-grid-lines div {
            flex: 1;
            border-left: 1px solid rgba(0,200,83,.05);
        }

            .wh-grid-lines div:last-child {
                border-right: 1px solid rgba(0,200,83,.05);
            }

    .wh-arc {
        position: absolute;
        border-radius: 50%;
        border: 1.5px solid rgba(0,200,83,.1);
        pointer-events: none;
        animation: arcPulse 5s ease-in-out infinite;
    }

    .wh-arc-1 {
        width: 700px;
        height: 700px;
        top: -200px;
        right: -150px;
        animation-delay: 0s;
    }

    .wh-arc-2 {
        width: 500px;
        height: 500px;
        bottom: -150px;
        left: -100px;
        animation-delay: 2.5s;
    }

    @@keyframes arcPulse {
        0%, 100% {
            opacity: .1;
            transform: scale(1);
        }

        50% {
