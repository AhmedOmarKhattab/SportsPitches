@model Pitch

@{
    ViewData["Title"] = "إضافة منتج";
}

<style>
    body {
        direction: rtl;
        text-align: right;
    }

    .form-card {
        border-radius: 15px;
        background: #fff;
    }

    .form-title {
        color: #0d6efd;
        font-weight: bold;
    }

    label {
        font-weight: 600;
        margin-bottom: 5px;
    }

    .form-control {
        border-radius: 10px;
    }

    .btn {
        border-radius: 10px;
        padding: 8px 20px;
    }
</style>

<br />

<h2 class="form-title mb-4">إضافة منتج جديد</h2>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div class="p-4 shadow-sm form-card">

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <h5 class="text-success">@ViewBag.messege</h5>

        <div class="row">

            <!-- الاسم -->
            <div class="col-md-6 mb-3">
                <label asp-for="Name">اسم المنتج</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <!-- السعر -->
            <div class="col-md-6 mb-3">
                <label asp-for="Price">السعر</label>
                <input asp-for="Price" class="form-control" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <!-- العنوان -->
            <div class="col-md-6 mb-3">
                <label asp-for="Address">العنوان</label>
                <input asp-for="Address" class="form-control" />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>

            
            <!-- النوع -->
            <div class="col-md-6 mb-3">
                <label asp-for="PitchTypeId">نوع المنتج</label>
                <select asp-for="PitchTypeId" asp-items="ViewBag.productTypeId" class="form-control"></select>
                <span asp-validation-for="PitchTypeId" class="text-danger"></span>
            </div>

            <!-- التصنيف -->
            <div class="col-md-6 mb-3">
                <label asp-for="SpecialTagId">التصنيف</label>
                <select asp-for="SpecialTagId" asp-items="ViewBag.TagId" class="form-control"></select>
                <span asp-validation-for="SpecialTagId" class="text-danger"></span>
            </div>

            
            <!-- الصورة -->
            <div class="col-md-6 mb-3">
                <label asp-for="Image">صورة المنتج</label>
                <input asp-for="Image" type="file" class="form-control" />
                <span asp-validation-for="Image" class="text-danger"></span>
            </div>

            <!-- الوصف -->
            <div class="col-12 mb-3">
                <label asp-for="Description">الوصف</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <!-- متوفر -->
            <div class="col-12 mb-3">
                <label>
                    <input asp-for="IsAvailable" type="checkbox" />
                    متوفر
                </label>
            </div>

        </div>

        <!-- الأزرار -->
        <div class="mt-4">
            <input type="submit" class="btn btn-primary" value="حفظ" />
            <a asp-action="Index" class="btn btn-outline-success">العودة للقائمة</a>
        </div>

    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}