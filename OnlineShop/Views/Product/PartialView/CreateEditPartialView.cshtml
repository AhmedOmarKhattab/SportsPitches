@model int

<td style="width:150px">
    <div class="btn-group">
        <!-- Edit Button -->
        <a asp-action="Edit" asp-controller="Product" class="btn btn-primary" asp-route-id="@Model">
            <i class="fas fa-pencil-alt"></i>
        </a>

        <!-- Details Button  -->
        <a asp-action="Details" asp-controller="Product" class="btn btn-success" asp-route-id="@Model">
            <i class="fas fa-list"></i>
        </a>

        <!-- Delete Button -->
        <a asp-action="Delete" asp-controller="Product" class="btn btn-danger" asp-route-id="@Model">
            <i class="fas fa-trash"></i>
        </a>
    </div>
</td>
